# ─────────────────────────────────────────────────────────────────────────────
# Production environment — career.pacificstar.ru
# Copy this file to .env.prod and fill in real values.
# .env.prod is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL (Docker Compose service name = postgres) ──────────────────────
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=change-me-strong-password

# Database URLs — use the compose service hostname "postgres"
DATABASE_URL="postgresql://hr_user:change-me-strong-password@postgres:5432/hr_system?schema=public"
# TEST_DATABASE_URL is not used in production; kept for reference only
# TEST_DATABASE_URL="postgresql://hr_user:change-me-strong-password@postgres:5432/hr_system_test?schema=public"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-truly-random-characters-here

COOKIE_SECURE=true

# Must match the public domain exactly
CORS_ORIGINS=https://career.pacificstar.ru

ACCESS_TOKEN_TTL_SECONDS=900        # 15 min
REFRESH_TOKEN_TTL_DAYS=30

# ── Bootstrap owner (idempotent seed — safe to re-run) ───────────────────────
BOOTSTRAP_TENANT_NAME=Pacific Star
BOOTSTRAP_OWNER_NAME=Администратор
BOOTSTRAP_OWNER_EMAIL=admin@pacificstar.ru
BOOTSTRAP_OWNER_PASSWORD=change-me-on-first-login

# ── Feature flags (all default false — flip when the key/service is ready) ───
CAREERS_PAGE_ENABLED=false
HH_INTEGRATION_ENABLED=false
AI_SCORING_ENABLED=false
ASSESSMENTS_ENABLED=false
# Phase 2 — 4-stage automated selection system
ASSESSMENT_SYSTEM_ENABLED=false
PROCTORING_WEBCAM_ENABLED=false
TRANSCRIPTION_ENABLED=false
EMAIL_ENABLED=false
TELEGRAM_ENABLED=false

# ── HH.ru integration (Phase 1A) ─────────────────────────────────────────────
# OAuth callback URL: https://career.pacificstar.ru/api/integrations/hh/callback
HH_CLIENT_ID=
HH_CLIENT_SECRET=
# Generate with: openssl rand -hex 16
HH_TOKEN_ENCRYPTION_KEY=

# ── AI scoring (Phase 1C) ─────────────────────────────────────────────────────
LLM_SCORING_PROVIDER=anthropic
LLM_SCORING_API_KEY=
LLM_SCORING_MODEL=claude-haiku-4-5-20251001

# ── Interview transcription (Phase 1F) ───────────────────────────────────────
ASR_PROVIDER=yandex_speechkit
ASR_API_KEY=
ASR_FOLDER_ID=
ASR_LANGUAGE=ru-RU
INTERVIEW_RECORDING_MAX_BYTES=524288000   # 500 MB

# ── DigitalOcean Spaces / S3-compatible storage ───────────────────────────────
SPACES_REGION=
SPACES_BUCKET=
SPACES_ENDPOINT=
SPACES_CDN_BASE_URL=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_UPLOAD_MAX_BYTES=10485760          # 10 MB
SPACES_UPLOAD_URL_TTL_SECONDS=900
SPACES_DOWNLOAD_URL_TTL_SECONDS=300

# ── Email (Phase 1E) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pacificstar.ru

# ── Telegram bot (Phase 1E) ───────────────────────────────────────────────────
# Webhook URL: https://career.pacificstar.ru/api/integrations/telegram/webhook
TELEGRAM_BOT_TOKEN=

# ── Quiet Hours (Vladivostok UTC+10 → Moscow UTC+3 active window) ────────────
# Quiet period: 15:00 UTC → 23:00 UTC (automated sends deferred)
# Active window: 23:00 UTC (09:00 VVO) → 15:00 UTC (18:00 MSK)
QUIET_HOURS_QUIET_START_UTC=15
QUIET_HOURS_QUIET_END_UTC=23

# ── Assessments / proctoring (Phase 1D) ──────────────────────────────────────
TRUST_WEIGHT_PASTE=0.35
TRUST_WEIGHT_FOCUS=0.4
TRUST_WEIGHT_KEYSTROKE=0.25
TRUST_LOW_THRESHOLD=50

# ── Careers page rate limiting ────────────────────────────────────────────────
CAREERS_RATE_LIMIT_PER_HOUR=20
