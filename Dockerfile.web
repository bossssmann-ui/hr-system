# ── Stage 1: build React SPA ─────────────────────────────────────────────────
FROM oven/bun:1.2-alpine AS builder
WORKDIR /app

# Copy workspace manifests for caching
COPY package.json bunfig.toml bun.lock ./
COPY packages/ ./packages/
COPY web/ ./web/

# Stub package.json for sibling workspaces so bun workspace resolution doesn't fail
COPY backend/package.json ./backend/package.json
COPY mobile/package.json ./mobile/package.json
COPY landing/package.json ./landing/package.json

RUN bun install --frozen-lockfile

ARG VITE_API_URL=https://career.pacificstar.ru
ENV VITE_API_URL=$VITE_API_URL

RUN cd web && bun run build

# ── Stage 2: serve static files with nginx ───────────────────────────────────
FROM nginx:1.27-alpine AS runner

COPY --from=builder /app/web/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
