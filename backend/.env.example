# Local PostgreSQL from ../docker-compose.yml.
# Keep an explicit username and password in Prisma URLs even on local machines.
# Peer-auth style URLs without a user can produce opaque Prisma schema-engine errors.
DATABASE_URL="postgresql://superuser:superpassword@localhost:54329/web_app_demo?schema=public"

# Test PostgreSQL from ../docker-compose.yml. Backend integration, Docker smoke,
# and Playwright E2E use this shape and must target the *_test database.
TEST_DATABASE_URL="postgresql://superuser:superpassword@localhost:54330/web_app_demo_test?schema=public"

JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="http://localhost:5173,http://localhost:8081,http://localhost:19006"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_DAYS="30"
COOKIE_SECURE="false"

# Optional HH.ru negotiations sync (Phase 1A). Keep disabled unless credentials
# are configured locally.
HH_INTEGRATION_ENABLED="false"
HH_CLIENT_ID=""
HH_CLIENT_SECRET=""
HH_TOKEN_ENCRYPTION_KEY=""

# Optional AI scoring (Phase 1C). Keep disabled unless configured.
AI_SCORING_ENABLED="false"
LLM_SCORING_PROVIDER="anthropic"
LLM_SCORING_API_KEY=""
LLM_SCORING_MODEL="claude-haiku-4-5-20251001"

# Optional interview transcription (Phase 1F). Keep disabled until configured.
# Set TRANSCRIPTION_ENABLED=true and provide ASR_API_KEY to enable.
# With the flag off, recording upload still works but transcription shows "not configured".
# See docs/contracts/10-data-model.md and docs/contracts/40-audit.md for 152-ФЗ notes.
TRANSCRIPTION_ENABLED="false"
ASR_PROVIDER="yandex_speechkit"
ASR_API_KEY=""
ASR_FOLDER_ID=""
ASR_LANGUAGE="ru-RU"
INTERVIEW_RECORDING_MAX_BYTES="524288000"

# Optional proctored assessments (Phase 1D). Disabled by default.
ASSESSMENTS_ENABLED="false"
PROCTORING_WEBCAM_ENABLED="false"
TRUST_WEIGHT_PASTE="0.35"
TRUST_WEIGHT_FOCUS="0.4"
TRUST_WEIGHT_KEYSTROKE="0.25"
TRUST_LOW_THRESHOLD="50"

# Optional DigitalOcean Spaces storage. Leave blank until the product needs
# uploads, media, or other persistent files.
SPACES_REGION=""
SPACES_BUCKET=""
SPACES_ENDPOINT=""
SPACES_CDN_BASE_URL=""
SPACES_ACCESS_KEY_ID=""
SPACES_SECRET_ACCESS_KEY=""
SPACES_UPLOAD_MAX_BYTES="10485760"
SPACES_UPLOAD_URL_TTL_SECONDS="900"
SPACES_DOWNLOAD_URL_TTL_SECONDS="300"
SPACES_PUBLIC_CACHE_CONTROL="public, max-age=31536000, immutable"

# Quiet Hours — automated outbound deferral (Phase 1E).
#
# Business context: this company spans Vladivostok (UTC+10) → Moscow (UTC+3).
# Active send window: 09:00 Vladivostok → 18:00 Moscow = 23:00 UTC → 15:00 UTC (wraps midnight).
# Automated messages sent outside this window are deferred until the window reopens.
#
# QUIET_HOURS_QUIET_START_UTC - UTC hour when the quiet period begins (default: 15 = 15:00 UTC)
# QUIET_HOURS_QUIET_END_UTC   - UTC hour when the quiet period ends / active resumes (default: 23 = 23:00 UTC)
QUIET_HOURS_QUIET_START_UTC="15"
QUIET_HOURS_QUIET_END_UTC="23"

# Bootstrap seed (see backend/prisma/seed.ts). Placeholder values only — do
# not commit real credentials. Generate a long random password for the owner
# user and store it in your local secret manager.
BOOTSTRAP_TENANT_NAME="HR-System"
BOOTSTRAP_OWNER_EMAIL="owner@example.com"
BOOTSTRAP_OWNER_PASSWORD="change-me-at-least-12-chars"
BOOTSTRAP_OWNER_NAME="HR-System Owner"
