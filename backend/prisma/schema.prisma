  assigneeUserId    String?              @map("assignee_user_id") @db.Uuid
  dueDate           DateTime?            @map("due_date") @db.Date
  completedAt       DateTime?            @map("completed_at")
  completedByUserId String?              @map("completed_by_user_id") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @default(now()) @updatedAt @map("updated_at")

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade, map: "onboarding_tasks_checklist_id_fkey")

  @@unique([checklistId, order], map: "onboarding_tasks_checklist_order_key")
  @@index([tenantId], map: "onboarding_tasks_tenant_id_idx")
  @@index([checklistId], map: "onboarding_tasks_checklist_id_idx")
  @@index([status], map: "onboarding_tasks_status_idx")
  @@map("onboarding_tasks")
}

model EmploymentDocument {
  id              String                   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String                   @map("tenant_id") @db.Uuid
