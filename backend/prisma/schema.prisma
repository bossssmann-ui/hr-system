model LearningCourse {
  id              String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  title           String
  description     String?
  contentType     LearningContentType @map("content_type")
  contentUrl      String?             @map("content_url")
  durationMinutes Int?                @map("duration_minutes")
  isMandatory     Boolean             @default(false) @map("is_mandatory")
  orgUnitId       String?             @map("org_unit_id") @db.Uuid
  createdByUserId String              @map("created_by_user_id") @db.Uuid
  deletedAt       DateTime?           @map("deleted_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at")

  orgUnit     OrgUnit?             @relation(fields: [orgUnitId], references: [id], onDelete: SetNull, map: "learning_courses_org_unit_id_fkey")
  assignments LearningAssignment[]
  pathItems   LearningPathItem[]

  @@index([tenantId], map: "learning_courses_tenant_id_idx")
  @@index([orgUnitId], map: "learning_courses_org_unit_id_idx")
  @@index([deletedAt], map: "learning_courses_deleted_at_idx")
  @@map("learning_courses")
}

model LearningPath {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  title           String
  description     String?
  roleFamily      String?   @map("role_family")
  autoAssign      Boolean   @default(false) @map("auto_assign")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  items       LearningPathItem[]
  assignments LearningAssignment[]

  @@index([tenantId], map: "learning_paths_tenant_id_idx")
  @@index([roleFamily], map: "learning_paths_role_family_idx")
  @@index([deletedAt], map: "learning_paths_deleted_at_idx")
  @@map("learning_paths")
}

model LearningPathItem {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  pathId    String   @map("path_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  order     Int      @map("item_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  path   LearningPath   @relation(fields: [pathId], references: [id], onDelete: Cascade, map: "learning_path_items_path_id_fkey")
  course LearningCourse @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "learning_path_items_course_id_fkey")

  @@unique([pathId, order], map: "learning_path_items_path_order_key")
  @@index([tenantId], map: "learning_path_items_tenant_id_idx")
  @@index([pathId], map: "learning_path_items_path_id_idx")
  @@map("learning_path_items")
}

model LearningAssignment {
  id               String                   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId         String                   @map("tenant_id") @db.Uuid
  employeeId       String                   @map("employee_id") @db.Uuid
  courseId         String?                  @map("course_id") @db.Uuid
  pathId           String?                  @map("path_id") @db.Uuid
  status           LearningAssignmentStatus @default(assigned)
  progressPercent  Int                      @default(0) @map("progress_percent")
  score            Int?
  dueDate          DateTime?                @map("due_date") @db.Date
  startedAt        DateTime?                @map("started_at")
  completedAt      DateTime?                @map("completed_at")
  assignedByUserId String                   @map("assigned_by_user_id") @db.Uuid
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @default(now()) @updatedAt @map("updated_at")

  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "learning_assignments_employee_id_fkey")
  course   LearningCourse? @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "learning_assignments_course_id_fkey")
  path     LearningPath?   @relation(fields: [pathId], references: [id], onDelete: Cascade, map: "learning_assignments_path_id_fkey")

  @@index([tenantId], map: "learning_assignments_tenant_id_idx")
  @@index([employeeId], map: "learning_assignments_employee_id_idx")
  @@index([status], map: "learning_assignments_status_idx")
  @@map("learning_assignments")
}

model OneOnOne {
  id              String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  employeeId      String         @map("employee_id") @db.Uuid
  managerUserId   String         @map("manager_user_id") @db.Uuid
  scheduledAt     DateTime       @map("scheduled_at")
  durationMinutes Int?           @map("duration_minutes")
  status          OneOnOneStatus @default(scheduled)
  agenda          String?
  notes           String?
  actionItems     Json           @default("[]") @map("action_items")
  reminderSentAt  DateTime?      @map("reminder_sent_at")
  completedAt     DateTime?      @map("completed_at")
  createdByUserId String         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "one_on_ones_employee_id_fkey")

  @@index([tenantId], map: "one_on_ones_tenant_id_idx")
  @@index([employeeId], map: "one_on_ones_employee_id_idx")
  @@index([managerUserId], map: "one_on_ones_manager_user_id_idx")
  @@index([scheduledAt], map: "one_on_ones_scheduled_at_idx")
  @@index([status], map: "one_on_ones_status_idx")
  @@map("one_on_ones")
}

model ReviewCycle {
  id              String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  title           String
  quarter         String
  status          ReviewCycleStatus @default(draft)
  questions       Json              @default("[]")
  openedAt        DateTime?         @map("opened_at")
  closesAt        DateTime?         @map("closes_at")
  closedAt        DateTime?         @map("closed_at")
  createdByUserId String            @map("created_by_user_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at")

  requests ReviewRequest[]

  @@index([tenantId], map: "review_cycles_tenant_id_idx")
  @@index([status], map: "review_cycles_status_idx")
  @@map("review_cycles")
}

model ReviewRequest {
  id                String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid
  cycleId           String              @map("cycle_id") @db.Uuid
  subjectEmployeeId String              @map("subject_employee_id") @db.Uuid
  reviewerUserId    String              @map("reviewer_user_id") @db.Uuid
  relationship      String              @default("peer")
  status            ReviewRequestStatus @default(pending)
  response          Json?
  declineReason     String?             @map("decline_reason")
  submittedAt       DateTime?           @map("submitted_at")
  declinedAt        DateTime?           @map("declined_at")
  reminderSentAt    DateTime?           @map("reminder_sent_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")

  cycle           ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, map: "review_requests_cycle_id_fkey")
  subjectEmployee Employee    @relation(fields: [subjectEmployeeId], references: [id], onDelete: Cascade, map: "review_requests_subject_employee_id_fkey")

  @@unique([cycleId, subjectEmployeeId, reviewerUserId], map: "review_requests_cycle_subject_reviewer_key")
  @@index([tenantId], map: "review_requests_tenant_id_idx")
  @@index([cycleId], map: "review_requests_cycle_id_idx")
  @@index([subjectEmployeeId], map: "review_requests_subject_employee_id_idx")
  @@index([reviewerUserId], map: "review_requests_reviewer_user_id_idx")
  @@index([status], map: "review_requests_status_idx")
  @@map("review_requests")
}

model Okr {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  employeeId      String    @map("employee_id") @db.Uuid
  parentOkrId     String?   @map("parent_okr_id") @db.Uuid
  quarter         String
  objective       String
  description     String?
  status          OkrStatus @default(draft)
  progressPercent Int       @default(0) @map("progress_percent")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "okrs_employee_id_fkey")
  parent     Okr?        @relation("OkrCascade", fields: [parentOkrId], references: [id], onDelete: SetNull, map: "okrs_parent_okr_id_fkey")
  children   Okr[]       @relation("OkrCascade")
  keyResults KeyResult[]

  @@index([tenantId], map: "okrs_tenant_id_idx")
  @@index([employeeId], map: "okrs_employee_id_idx")
  @@index([quarter], map: "okrs_quarter_idx")
  @@index([parentOkrId], map: "okrs_parent_okr_id_idx")
  @@map("okrs")
}

model KeyResult {
  id           String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  okrId        String          @map("okr_id") @db.Uuid
  title        String
  unit         String?
  startValue   Float           @default(0) @map("start_value")
  targetValue  Float           @map("target_value")
  currentValue Float           @default(0) @map("current_value")
  status       KeyResultStatus @default(open)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at")

  okr Okr @relation(fields: [okrId], references: [id], onDelete: Cascade, map: "key_results_okr_id_fkey")

  @@index([tenantId], map: "key_results_tenant_id_idx")
  @@index([okrId], map: "key_results_okr_id_idx")
  @@map("key_results")
}

model Idp {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  employeeId      String    @map("employee_id") @db.Uuid
  quarter         String
  summary         String?
  status          IdpStatus @default(draft)
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "idps_employee_id_fkey")
  items    IdpItem[]

  @@unique([employeeId, quarter], map: "idps_employee_quarter_key")
  @@index([tenantId], map: "idps_tenant_id_idx")
  @@index([employeeId], map: "idps_employee_id_idx")
  @@map("idps")
}

model IdpItem {
  id          String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  idpId       String        @map("idp_id") @db.Uuid
  title       String
  description String?
  status      IdpItemStatus @default(planned)
  dueDate     DateTime?     @map("due_date") @db.Date
  completedAt DateTime?     @map("completed_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")

  idp Idp @relation(fields: [idpId], references: [id], onDelete: Cascade, map: "idp_items_idp_id_fkey")

  @@index([tenantId], map: "idp_items_tenant_id_idx")
  @@index([idpId], map: "idp_items_idp_id_idx")
  @@map("idp_items")
}

