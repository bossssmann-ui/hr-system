enum CompPlanStatus {
  draft
  approved
  applied

  @@map("comp_plan_status")
}

model HrSnapshot {
  id                   String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  snapshotDate         DateTime @map("snapshot_date") @db.Date
  headcount            Int
  headcountByStatus    Json     @default("{}") @map("headcount_by_status")
  headcountByOrgUnit   Json     @default("{}") @map("headcount_by_org_unit")
  openRequisitions     Int      @default(0) @map("open_requisitions")
  hiredMtd             Int      @default(0) @map("hired_mtd")
  terminatedMtd        Int      @default(0) @map("terminated_mtd")
  avgTimeToHireDays    Decimal? @map("avg_time_to_hire_days") @db.Decimal(10, 2)
  probationPassRateQtd Decimal? @map("probation_pass_rate_qtd") @db.Decimal(5, 2)
