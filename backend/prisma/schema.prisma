}

model CompPlan {
  id               String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  name             String
  effectiveDate    DateTime       @map("effective_date") @db.Date
  budgetCurrency   Currency
  budgetTotal      Int            @default(0) @map("budget_total")
  status           CompPlanStatus @default(draft)
  notes            String?
  createdByUserId  String         @map("created_by_user_id") @db.Uuid
  approvedByUserId String?        @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime?      @map("approved_at")
  appliedAt        DateTime?      @map("applied_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  items CompPlanItem[]

  @@index([tenantId], map: "comp_plans_tenant_id_idx")
  @@index([status], map: "comp_plans_status_idx")
  @@map("comp_plans")
}

model CompPlanItem {
  id             String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  planId         String   @map("plan_id") @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  currentSalary  Int      @map("current_salary")
  proposedSalary Int      @map("proposed_salary")
  currency       Currency
  changePct      Decimal  @map("change_pct") @db.Decimal(7, 2)
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
