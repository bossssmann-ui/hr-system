  @@index([employeeId], map: "employment_documents_employee_id_idx")
  @@index([type], map: "employment_documents_type_idx")
  @@index([status], map: "employment_documents_status_idx")
  @@map("employment_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 4.7 — Pre-start inbox / first-day plan
// Spec: docs/employee-lifecycle-design.md §5.3 (roadmap §7.4).
// Opened on `Application.offer → hired` alongside the Employee row. Gated by
// `Employee.user_id IS NOT NULL`: while no portal user is linked the entry
// sits in `pending_link` and surfaces nothing to the candidate.
// ─────────────────────────────────────────────────────────────────────────────

model PreStartPortalEntry {
  id         String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId   String               @map("tenant_id") @db.Uuid
