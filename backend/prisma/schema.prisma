  status     PreStartPortalStatus @default(pending_link)
  openedAt   DateTime             @default(now()) @map("opened_at")
  linkedAt   DateTime?            @map("linked_at")
  closedAt   DateTime?            @map("closed_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @default(now()) @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "pre_start_portal_entries_employee_id_fkey")

  @@index([tenantId], map: "pre_start_portal_entries_tenant_id_idx")
  @@index([status], map: "pre_start_portal_entries_status_idx")
  @@map("pre_start_portal_entries")
}

model OffboardingChecklist {
  id          String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
