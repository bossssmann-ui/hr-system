generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum RoleName {
  owner
  hr_admin
  recruiter
  hiring_manager
  employee
  candidate
}

enum Currency {
  RUB
  USD
  THB
  USDT
}

enum RequisitionStatus {
  draft
  submitted
  manager_approved
  hr_approved
  approved
  in_recruitment
  closed
  rejected
}

enum CandidateSource {
  manual
  hh_ru
  sberpodbor
  avito
  rabota_ru
  referral
  careers_page
}

enum ApplicationStage {
  new
  screen
  tech
  final
  offer
  hired
  rejected
}

enum AssessmentQuestionType {
  open
  single_choice
  multi_choice
}

enum AssessmentSessionStatus {
  invited
  consented
  in_progress
  submitted
  graded
  expired
}

enum NotificationChannel {
  email
  telegram
  in_app
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant (single bootstrap tenant in Phase 0)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email        String        @unique
  passwordHash String        @map("password_hash")
  displayName  String?       @map("display_name")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  sessions     AuthSession[]
  roles        UserRole[]

  @@map("users")
}

model AuthSession {
  id               String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId           String    @db.Uuid @map("user_id")
  refreshTokenHash String    @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "auth_sessions_user_id_fkey")

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model UserRole {
  userId    String   @db.Uuid @map("user_id")
  role      RoleName
  tenantId  String   @db.Uuid @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "user_roles_user_id_fkey")

  @@id([userId, role, tenantId])
  @@index([tenantId], map: "user_roles_tenant_id_idx")
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Org structure
// ─────────────────────────────────────────────────────────────────────────────

model OrgUnit {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  name      String
  parentId  String?  @db.Uuid @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   OrgUnit?  @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: SetNull, map: "org_units_parent_id_fkey")
  children OrgUnit[] @relation("OrgUnitTree")

  requisitions HiringRequisition[]
  vacancies    Vacancy[]

  @@index([tenantId], map: "org_units_tenant_id_idx")
  @@index([parentId], map: "org_units_parent_id_idx")
  @@map("org_units")
}

// ─────────────────────────────────────────────────────────────────────────────
// Recruiting
// ─────────────────────────────────────────────────────────────────────────────

model HiringRequisition {
  id              String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String            @db.Uuid @map("tenant_id")
  orgUnitId       String            @db.Uuid @map("org_unit_id")
  createdByUserId String            @db.Uuid @map("created_by_user_id")
  title           String
  grade           String
  salaryMin       Int               @map("salary_min")
  salaryMax       Int               @map("salary_max")
  currency        Currency
  justification   String
  status          RequisitionStatus @default(draft)
  deadlineAt      DateTime?         @map("deadline_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  orgUnit OrgUnit  @relation(fields: [orgUnitId], references: [id], map: "hiring_requisitions_org_unit_id_fkey")
  vacancy Vacancy?

  @@index([tenantId], map: "hiring_requisitions_tenant_id_idx")
  @@index([orgUnitId], map: "hiring_requisitions_org_unit_id_idx")
  @@index([createdByUserId], map: "hiring_requisitions_created_by_user_id_idx")
  @@index([status], map: "hiring_requisitions_status_idx")
  @@map("hiring_requisitions")
}

model Vacancy {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String   @db.Uuid @map("tenant_id")
  requisitionId String   @unique @db.Uuid @map("requisition_id")
  orgUnitId     String   @db.Uuid @map("org_unit_id")
  hhVacancyId   String?  @unique @map("hh_vacancy_id")
  slug          String?  @map("slug")
  title         String
  description   String
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  requisition  HiringRequisition @relation(fields: [requisitionId], references: [id], map: "vacancies_requisition_id_fkey")
  orgUnit      OrgUnit           @relation(fields: [orgUnitId], references: [id], map: "vacancies_org_unit_id_fkey")
  applications Application[]
  hhSyncCursor HhSyncCursor?
  assessmentTemplates AssessmentTemplate[]

  @@unique([tenantId, slug], map: "vacancies_tenant_id_slug_key")
  @@index([tenantId], map: "vacancies_tenant_id_idx")
  @@index([orgUnitId], map: "vacancies_org_unit_id_idx")
  @@map("vacancies")
}

model Candidate {
  id          String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String          @db.Uuid @map("tenant_id")
  fullName    String          @map("full_name")
  email       String?
  phone       String?
  location    String?
  source      CandidateSource @default(manual)
  externalIds Json            @default("{}") @map("external_ids")
  consentContext Json?        @map("consent_context")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  resumes       Resume[]
  applications  Application[]
  conversations Conversation[]

  // Email and phone are unique only when non-null; expressed at the SQL layer
  // via partial UNIQUE indexes added in the migration (Prisma cannot model
  // partial indexes declaratively). See `30-rls-policies.md` and the migration.
  @@index([tenantId], map: "candidates_tenant_id_idx")
  @@map("candidates")
}

model Resume {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId       String    @db.Uuid @map("tenant_id")
  candidateId    String    @db.Uuid @map("candidate_id")
  fileUrl        String    @map("file_url")
  parsedPayload  Json?     @map("parsed_payload")
  uploadedAt     DateTime  @default(now()) @map("uploaded_at")
  deletedAt      DateTime? @map("deleted_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade, map: "resumes_candidate_id_fkey")

  @@index([tenantId], map: "resumes_tenant_id_idx")
  @@index([candidateId], map: "resumes_candidate_id_idx")
  @@map("resumes")
}

model Application {
  id                String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String           @db.Uuid @map("tenant_id")
  candidateId       String           @db.Uuid @map("candidate_id")
  vacancyId         String           @db.Uuid @map("vacancy_id")
  stage             ApplicationStage @default(new)
  assignedToUserId  String?          @db.Uuid @map("assigned_to_user_id")
  notes             String?
  aiScoring         Json?            @map("ai_scoring")
  aiScoreFeedback   Json?            @map("ai_score_feedback")
  aiInterviewQuestions Json?         @map("ai_interview_questions")
  trustFlagged      Boolean          @default(false) @map("trust_flagged")
  externalIds       Json             @default("{}") @map("external_ids")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  candidate    Candidate                @relation(fields: [candidateId], references: [id], map: "applications_candidate_id_fkey")
  vacancy      Vacancy                  @relation(fields: [vacancyId], references: [id], map: "applications_vacancy_id_fkey")
  stageEvents  ApplicationStageEvent[]
  interviews   Interview[]
  conversations Conversation[]
  assessmentSessions AssessmentSession[]

  @@unique([candidateId, vacancyId], map: "applications_candidate_vacancy_unique")
  @@index([tenantId], map: "applications_tenant_id_idx")
  @@index([vacancyId], map: "applications_vacancy_id_idx")
  @@index([stage], map: "applications_stage_idx")
  @@index([assignedToUserId], map: "applications_assigned_to_user_id_idx")
  @@map("applications")
}

model AssessmentTemplate {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId     String   @db.Uuid @map("tenant_id")
  vacancyId    String?  @db.Uuid @map("vacancy_id")
  title        String
  description  String?
  timeLimitMin Int?     @map("time_limit_min")
  createdBy    String   @db.Uuid @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vacancy  Vacancy?               @relation(fields: [vacancyId], references: [id], onDelete: SetNull, map: "assessment_templates_vacancy_id_fkey")
  questions AssessmentQuestion[]
  sessions  AssessmentSession[]

  @@index([tenantId], map: "assessment_templates_tenant_id_idx")
  @@index([vacancyId], map: "assessment_templates_vacancy_id_idx")
  @@map("assessment_templates")
}

model AssessmentQuestion {
  id         String                 @id @default(dbgenerated("uuidv7()")) @db.Uuid
  templateId String                 @db.Uuid @map("template_id")
  order      Int                    @map("question_order")
  type       AssessmentQuestionType
  prompt     String
  options    Json?
  rubric     String?
  competency String?
  weight     Float                  @default(1)
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  template AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "assessment_questions_template_id_fkey")
  answers  AssessmentAnswer[]

  @@index([templateId], map: "assessment_questions_template_id_idx")
  @@unique([templateId, order], map: "assessment_questions_template_order_key")
  @@map("assessment_questions")
}

model AssessmentSession {
  id              String                  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String                  @db.Uuid @map("tenant_id")
  templateId      String                  @db.Uuid @map("template_id")
  applicationId   String                  @db.Uuid @map("application_id")
  inviteToken     String                  @unique @map("invite_token")
  status          AssessmentSessionStatus @default(invited)
  consentRecorded Boolean                 @default(false) @map("consent_recorded")
  startedAt       DateTime?               @map("started_at")
  submittedAt     DateTime?               @map("submitted_at")
  trustScore      Int?                    @map("trust_score")
  trustSignals    Json?                   @map("trust_signals")
  createdAt       DateTime                @default(now()) @map("created_at")

  template    AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "assessment_sessions_template_id_fkey")
  application Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade, map: "assessment_sessions_application_id_fkey")
  answers     AssessmentAnswer[]

  @@index([tenantId], map: "assessment_sessions_tenant_id_idx")
  @@index([applicationId], map: "assessment_sessions_application_id_idx")
  @@map("assessment_sessions")
}

model AssessmentAnswer {
  id         String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  sessionId  String   @db.Uuid @map("session_id")
  questionId String   @db.Uuid @map("question_id")
  answer     Json
  aiGrade    Json?    @map("ai_grade")
  createdAt  DateTime @default(now()) @map("created_at")

  session  AssessmentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "assessment_answers_session_id_fkey")
  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade, map: "assessment_answers_question_id_fkey")

  @@index([sessionId], map: "assessment_answers_session_id_idx")
  @@index([questionId], map: "assessment_answers_question_id_idx")
  @@unique([sessionId, questionId], map: "assessment_answers_session_question_key")
  @@map("assessment_answers")
}

model ApplicationStageEvent {
  id            String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String           @db.Uuid @map("tenant_id")
  applicationId String           @db.Uuid @map("application_id")
  fromStage     ApplicationStage @map("from_stage")
  toStage       ApplicationStage @map("to_stage")
  actorUserId   String           @db.Uuid @map("actor_user_id")
  comment       String?
  createdAt     DateTime         @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, map: "application_stage_events_application_id_fkey")

  @@index([tenantId], map: "application_stage_events_tenant_id_idx")
  @@index([applicationId], map: "application_stage_events_application_id_idx")
  @@index([actorUserId], map: "application_stage_events_actor_user_id_idx")
  @@map("application_stage_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Cross-cutting
// ─────────────────────────────────────────────────────────────────────────────

model AuditEvent {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  actorUserId String?  @db.Uuid @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @db.Uuid @map("entity_id")
  diff        Json
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId], map: "audit_events_entity_idx")
  @@index([actorUserId, createdAt], map: "audit_events_actor_created_idx")
  @@index([tenantId], map: "audit_events_tenant_id_idx")
  @@map("audit_events")
}

model Notification {
  id              String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String              @db.Uuid @map("tenant_id")
  recipientUserId String              @db.Uuid @map("recipient_user_id")
  channel         NotificationChannel
  template        String
  payload         Json                @default("{}")
  readAt          DateTime?           @map("read_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@index([tenantId], map: "notifications_tenant_id_idx")
  @@index([recipientUserId, readAt], map: "notifications_recipient_read_idx")
  @@map("notifications")
}

model HhConnection {
  id                  String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId            String   @unique @db.Uuid @map("tenant_id")
  accessToken         String   @map("access_token")
  refreshToken        String   @map("refresh_token")
  tokenExpiresAt      DateTime @map("token_expires_at")
  connectedEmployerId String?  @map("connected_employer_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([tenantId], map: "hh_connections_tenant_id_idx")
  @@map("hh_connections")
}

model HhSyncCursor {
  id                String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String   @db.Uuid @map("tenant_id")
  vacancyId         String   @unique @db.Uuid @map("vacancy_id")
  lastSyncedAt      DateTime? @map("last_synced_at")
  lastNegotiationId String?   @map("last_negotiation_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade, map: "hh_sync_cursors_vacancy_id_fkey")

  @@index([tenantId], map: "hh_sync_cursors_tenant_id_idx")
  @@index([vacancyId], map: "hh_sync_cursors_vacancy_id_idx")
  @@map("hh_sync_cursors")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 1E — Candidate Messenger
// ─────────────────────────────────────────────────────────────────────────────

enum MessageChannelType {
  in_app
  email
  telegram
  hh_chat

  @@map("message_channel_type")
}

enum MessageDirection {
  inbound
  outbound

  @@map("message_direction")
}

enum MessageStatus {
  draft
  queued
  sent
  delivered
  failed
  received

  @@map("message_status")
}

model Conversation {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  candidateId   String    @db.Uuid @map("candidate_id")
  applicationId String?   @db.Uuid @map("application_id")
  subject       String?
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade, map: "conversations_candidate_id_fkey")
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull, map: "conversations_application_id_fkey")
  messages    Message[]

  @@index([tenantId], map: "conversations_tenant_id_idx")
  @@index([candidateId], map: "conversations_candidate_id_idx")
  @@index([applicationId], map: "conversations_application_id_idx")
  @@map("conversations")
}

model Message {
  id             String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId       String             @db.Uuid @map("tenant_id")
  conversationId String             @db.Uuid @map("conversation_id")
  channel        MessageChannelType
  direction      MessageDirection
  body           String
  senderUserId   String?            @db.Uuid @map("sender_user_id")
  externalId     String?            @map("external_id")
  status         MessageStatus      @default(draft)
  sentAt         DateTime?          @map("sent_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "messages_conversation_id_fkey")

  // Partial unique index (channel, external_id) where external_id IS NOT NULL
  // enforced at the SQL layer in the migration for inbound dedup.
  @@index([tenantId], map: "messages_tenant_id_idx")
  @@index([conversationId], map: "messages_conversation_id_idx")
  @@index([channel, externalId], map: "messages_channel_external_id_idx")
  @@map("messages")
}

model MessageTemplate {
  id            String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String             @db.Uuid @map("tenant_id")
  name          String
  channel       MessageChannelType?
  subject       String?
  body          String
  createdByUserId String           @db.Uuid @map("created_by_user_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([tenantId], map: "message_templates_tenant_id_idx")
  @@map("message_templates")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 1F — Interview / Transcription / Protocol / Offer Draft
// ─────────────────────────────────────────────────────────────────────────────

enum InterviewStatus {
  created
  transcribing
  transcribed
  protocol_ready
  failed
}

model Interview {
  id                String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String          @db.Uuid @map("tenant_id")
  applicationId     String          @db.Uuid @map("application_id")
  scheduledAt       DateTime?       @map("scheduled_at")
  recordingUrl      String?         @map("recording_url")
  consentRecorded   Boolean         @default(false) @map("consent_recorded")
  status            InterviewStatus @default(created)
  transcript        Json?
  protocol          Json?
  offerDraft        Json?           @map("offer_draft")
  createdByUserId   String          @db.Uuid @map("created_by_user_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, map: "interviews_application_id_fkey")

  @@index([tenantId], map: "interviews_tenant_id_idx")
  @@index([applicationId], map: "interviews_application_id_idx")
  @@map("interviews")
}
