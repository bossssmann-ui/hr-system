generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum RoleName {
  owner
  hr_admin
  recruiter
  hiring_manager
  employee
  candidate
}

enum Currency {
  RUB
  USD
  THB
  USDT
}

enum RequisitionStatus {
  draft
  submitted
  manager_approved
  hr_approved
  approved
  in_recruitment
  closed
  rejected
}

enum CandidateSource {
  manual
  hh_ru
  sberpodbor
  avito
  rabota_ru
  referral
  careers_page
}

enum ApplicationStage {
  new
  screen
  tech
  final
  offer
  hired
  rejected
}

enum OfferStatus {
  draft
  manager_review
  approved
  sent
  accepted
  declined
  expired
}

enum AssessmentQuestionType {
  open
  single_choice
  multi_choice
}

enum AssessmentSessionStatus {
  invited
  consented
  in_progress
  submitted
  graded
  expired
}

enum NotificationChannel {
  email
  telegram
  in_app
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant (single bootstrap tenant in Phase 0)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email        String        @unique
  passwordHash String        @map("password_hash")
  displayName  String?       @map("display_name")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  disabledAt   DateTime?     @map("disabled_at")
  sessions     AuthSession[]
  roles        UserRole[]
  employee     Employee?

  @@map("users")
}

model AuthSession {
  id               String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId           String    @db.Uuid @map("user_id")
  refreshTokenHash String    @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "auth_sessions_user_id_fkey")

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model UserRole {
  userId    String   @db.Uuid @map("user_id")
  role      RoleName
  tenantId  String   @db.Uuid @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "user_roles_user_id_fkey")

  @@id([userId, role, tenantId])
  @@index([tenantId], map: "user_roles_tenant_id_idx")
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Org structure
// ─────────────────────────────────────────────────────────────────────────────

model OrgUnit {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  name      String
  parentId  String?  @db.Uuid @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   OrgUnit?  @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: SetNull, map: "org_units_parent_id_fkey")
  children OrgUnit[] @relation("OrgUnitTree")

  requisitions HiringRequisition[]
  vacancies    Vacancy[]
  employees    Employee[]
  learningCourses LearningCourse[]

  @@index([tenantId], map: "org_units_tenant_id_idx")
  @@index([parentId], map: "org_units_parent_id_idx")
  @@map("org_units")
}

// ─────────────────────────────────────────────────────────────────────────────
// Recruiting
// ─────────────────────────────────────────────────────────────────────────────

model HiringRequisition {
  id              String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String            @db.Uuid @map("tenant_id")
  orgUnitId       String            @db.Uuid @map("org_unit_id")
  createdByUserId String            @db.Uuid @map("created_by_user_id")
  title           String
  grade           String
  salaryMin       Int               @map("salary_min")
  salaryMax       Int               @map("salary_max")
  currency        Currency
  justification   String
  status          RequisitionStatus @default(draft)
  deadlineAt      DateTime?         @map("deadline_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  orgUnit OrgUnit  @relation(fields: [orgUnitId], references: [id], map: "hiring_requisitions_org_unit_id_fkey")
  vacancy    Vacancy?
  employees  Employee[]

  @@index([tenantId], map: "hiring_requisitions_tenant_id_idx")
  @@index([orgUnitId], map: "hiring_requisitions_org_unit_id_idx")
  @@index([createdByUserId], map: "hiring_requisitions_created_by_user_id_idx")
  @@index([status], map: "hiring_requisitions_status_idx")
  @@map("hiring_requisitions")
}

model Vacancy {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String   @db.Uuid @map("tenant_id")
  requisitionId String   @unique @db.Uuid @map("requisition_id")
  orgUnitId     String   @db.Uuid @map("org_unit_id")
  hhVacancyId   String?  @unique @map("hh_vacancy_id")
  slug          String?  @map("slug")
  title         String
  description   String
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  requisition  HiringRequisition @relation(fields: [requisitionId], references: [id], map: "vacancies_requisition_id_fkey")
  orgUnit      OrgUnit           @relation(fields: [orgUnitId], references: [id], map: "vacancies_org_unit_id_fkey")
  applications Application[]
  hhSyncCursor HhSyncCursor?
  assessmentTemplates AssessmentTemplate[]
  selectionTemplates  SelectionTemplate[]  @relation("SelectionTemplates")

  @@unique([tenantId, slug], map: "vacancies_tenant_id_slug_key")
  @@index([tenantId], map: "vacancies_tenant_id_idx")
  @@index([orgUnitId], map: "vacancies_org_unit_id_idx")
  @@map("vacancies")
}

model Candidate {
  id          String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String          @db.Uuid @map("tenant_id")
  fullName    String          @map("full_name")
  email       String?
  phone       String?
  location    String?
  source      CandidateSource @default(manual)
  externalIds Json            @default("{}") @map("external_ids")
  consentContext Json?        @map("consent_context")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  resumes       Resume[]
  applications  Application[]
  conversations Conversation[]
  employees     Employee[]
  alumniProfiles AlumniProfile[]

  // Email and phone are unique only when non-null; expressed at the SQL layer
  // via partial UNIQUE indexes added in the migration (Prisma cannot model
  // partial indexes declaratively). See `30-rls-policies.md` and the migration.
  @@index([tenantId], map: "candidates_tenant_id_idx")
  @@map("candidates")
}

model Resume {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId       String    @db.Uuid @map("tenant_id")
  candidateId    String    @db.Uuid @map("candidate_id")
  fileUrl        String    @map("file_url")
  parsedPayload  Json?     @map("parsed_payload")
  uploadedAt     DateTime  @default(now()) @map("uploaded_at")
  deletedAt      DateTime? @map("deleted_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade, map: "resumes_candidate_id_fkey")

  @@index([tenantId], map: "resumes_tenant_id_idx")
  @@index([candidateId], map: "resumes_candidate_id_idx")
  @@map("resumes")
}

model Application {
  id                String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String           @db.Uuid @map("tenant_id")
  candidateId       String           @db.Uuid @map("candidate_id")
  vacancyId         String           @db.Uuid @map("vacancy_id")
  stage             ApplicationStage @default(new)
  assignedToUserId  String?          @db.Uuid @map("assigned_to_user_id")
  notes             String?
  aiScoring         Json?            @map("ai_scoring")
  aiScoreFeedback   Json?            @map("ai_score_feedback")
  aiInterviewQuestions Json?         @map("ai_interview_questions")
  trustFlagged      Boolean          @default(false) @map("trust_flagged")
  externalIds       Json             @default("{}") @map("external_ids")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  candidate    Candidate                @relation(fields: [candidateId], references: [id], map: "applications_candidate_id_fkey")
  vacancy      Vacancy                  @relation(fields: [vacancyId], references: [id], map: "applications_vacancy_id_fkey")
  stageEvents  ApplicationStageEvent[]
  interviews   Interview[]
  conversations Conversation[]
  assessmentSessions AssessmentSession[]
  employee     Employee?
  offers       Offer[]

  @@unique([candidateId, vacancyId], map: "applications_candidate_vacancy_unique")
  @@index([tenantId], map: "applications_tenant_id_idx")
  @@index([vacancyId], map: "applications_vacancy_id_idx")
  @@index([stage], map: "applications_stage_idx")
  @@index([assignedToUserId], map: "applications_assigned_to_user_id_idx")
  @@map("applications")
}

model AssessmentTemplate {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId     String   @db.Uuid @map("tenant_id")
  vacancyId    String?  @db.Uuid @map("vacancy_id")
  title        String
  description  String?
  timeLimitMin Int?     @map("time_limit_min")
  createdBy    String   @db.Uuid @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vacancy  Vacancy?               @relation(fields: [vacancyId], references: [id], onDelete: SetNull, map: "assessment_templates_vacancy_id_fkey")
  questions AssessmentQuestion[]
  sessions  AssessmentSession[]

  @@index([tenantId], map: "assessment_templates_tenant_id_idx")
  @@index([vacancyId], map: "assessment_templates_vacancy_id_idx")
  @@map("assessment_templates")
}

model AssessmentQuestion {
  id         String                 @id @default(dbgenerated("uuidv7()")) @db.Uuid
  templateId String                 @db.Uuid @map("template_id")
  order      Int                    @map("question_order")
  type       AssessmentQuestionType
  prompt     String
  options    Json?
  rubric     String?
  competency String?
  weight     Float                  @default(1)
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  template AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "assessment_questions_template_id_fkey")
  answers  AssessmentAnswer[]

  @@index([templateId], map: "assessment_questions_template_id_idx")
  @@unique([templateId, order], map: "assessment_questions_template_order_key")
  @@map("assessment_questions")
}

model AssessmentSession {
  id              String                  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String                  @db.Uuid @map("tenant_id")
  templateId      String                  @db.Uuid @map("template_id")
  applicationId   String                  @db.Uuid @map("application_id")
  inviteToken     String                  @unique @map("invite_token")
  status          AssessmentSessionStatus @default(invited)
  consentRecorded Boolean                 @default(false) @map("consent_recorded")
  startedAt       DateTime?               @map("started_at")
  submittedAt     DateTime?               @map("submitted_at")
  trustScore      Int?                    @map("trust_score")
  trustSignals    Json?                   @map("trust_signals")
  createdAt       DateTime                @default(now()) @map("created_at")

  template    AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "assessment_sessions_template_id_fkey")
  application Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade, map: "assessment_sessions_application_id_fkey")
  answers     AssessmentAnswer[]

  @@index([tenantId], map: "assessment_sessions_tenant_id_idx")
  @@index([applicationId], map: "assessment_sessions_application_id_idx")
  @@map("assessment_sessions")
}

model AssessmentAnswer {
  id         String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  sessionId  String   @db.Uuid @map("session_id")
  questionId String   @db.Uuid @map("question_id")
  answer     Json
  aiGrade    Json?    @map("ai_grade")
  createdAt  DateTime @default(now()) @map("created_at")

  session  AssessmentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "assessment_answers_session_id_fkey")
  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade, map: "assessment_answers_question_id_fkey")

  @@index([sessionId], map: "assessment_answers_session_id_idx")
  @@index([questionId], map: "assessment_answers_question_id_idx")
  @@unique([sessionId, questionId], map: "assessment_answers_session_question_key")
  @@map("assessment_answers")
}

model ApplicationStageEvent {
  id            String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String           @db.Uuid @map("tenant_id")
  applicationId String           @db.Uuid @map("application_id")
  fromStage     ApplicationStage @map("from_stage")
  toStage       ApplicationStage @map("to_stage")
  actorUserId   String           @db.Uuid @map("actor_user_id")
  comment       String?
  createdAt     DateTime         @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, map: "application_stage_events_application_id_fkey")

  @@index([tenantId], map: "application_stage_events_tenant_id_idx")
  @@index([applicationId], map: "application_stage_events_application_id_idx")
  @@index([actorUserId], map: "application_stage_events_actor_user_id_idx")
  @@map("application_stage_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Cross-cutting
// ─────────────────────────────────────────────────────────────────────────────

model AuditEvent {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  actorUserId String?  @db.Uuid @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @db.Uuid @map("entity_id")
  diff        Json
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId], map: "audit_events_entity_idx")
  @@index([actorUserId, createdAt], map: "audit_events_actor_created_idx")
  @@index([tenantId], map: "audit_events_tenant_id_idx")
  @@map("audit_events")
}

model Notification {
  id              String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String              @db.Uuid @map("tenant_id")
  recipientUserId String              @db.Uuid @map("recipient_user_id")
  channel         NotificationChannel
  template        String
  payload         Json                @default("{}")
  readAt          DateTime?           @map("read_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@index([tenantId], map: "notifications_tenant_id_idx")
  @@index([recipientUserId, readAt], map: "notifications_recipient_read_idx")
  @@map("notifications")
}

model HhConnection {
  id                  String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId            String   @unique @db.Uuid @map("tenant_id")
  accessToken         String   @map("access_token")
  refreshToken        String   @map("refresh_token")
  tokenExpiresAt      DateTime @map("token_expires_at")
  connectedEmployerId String?  @map("connected_employer_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([tenantId], map: "hh_connections_tenant_id_idx")
  @@map("hh_connections")
}

model HhSyncCursor {
  id                String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String   @db.Uuid @map("tenant_id")
  vacancyId         String   @unique @db.Uuid @map("vacancy_id")
  lastSyncedAt      DateTime? @map("last_synced_at")
  lastNegotiationId String?   @map("last_negotiation_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade, map: "hh_sync_cursors_vacancy_id_fkey")

  @@index([tenantId], map: "hh_sync_cursors_tenant_id_idx")
  @@index([vacancyId], map: "hh_sync_cursors_vacancy_id_idx")
  @@map("hh_sync_cursors")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 1E — Candidate Messenger
// ─────────────────────────────────────────────────────────────────────────────

enum MessageChannelType {
  in_app
  email
  telegram
  hh_chat

  @@map("message_channel_type")
}

enum MessageDirection {
  inbound
  outbound

  @@map("message_direction")
}

enum MessageStatus {
  draft
  queued
  sent
  delivered
  failed
  received

  @@map("message_status")
}

model Conversation {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  candidateId   String    @db.Uuid @map("candidate_id")
  applicationId String?   @db.Uuid @map("application_id")
  subject       String?
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade, map: "conversations_candidate_id_fkey")
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull, map: "conversations_application_id_fkey")
  messages    Message[]

  @@index([tenantId], map: "conversations_tenant_id_idx")
  @@index([candidateId], map: "conversations_candidate_id_idx")
  @@index([applicationId], map: "conversations_application_id_idx")
  @@map("conversations")
}

model Message {
  id             String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId       String             @db.Uuid @map("tenant_id")
  conversationId String             @db.Uuid @map("conversation_id")
  channel        MessageChannelType
  direction      MessageDirection
  body           String
  senderUserId   String?            @db.Uuid @map("sender_user_id")
  externalId     String?            @map("external_id")
  status         MessageStatus      @default(draft)
  sentAt         DateTime?          @map("sent_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "messages_conversation_id_fkey")

  // Partial unique index (channel, external_id) where external_id IS NOT NULL
  // enforced at the SQL layer in the migration for inbound dedup.
  @@index([tenantId], map: "messages_tenant_id_idx")
  @@index([conversationId], map: "messages_conversation_id_idx")
  @@index([channel, externalId], map: "messages_channel_external_id_idx")
  @@map("messages")
}

model MessageTemplate {
  id            String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String             @db.Uuid @map("tenant_id")
  name          String
  channel       MessageChannelType?
  subject       String?
  body          String
  createdByUserId String           @db.Uuid @map("created_by_user_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([tenantId], map: "message_templates_tenant_id_idx")
  @@map("message_templates")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — Automated Selection System (Onboardix 4-stage screening)
// ─────────────────────────────────────────────────────────────────────────────

model SelectionTemplate {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  vacancyId String   @db.Uuid @map("vacancy_id")
  role      String   // 'logist' | 'sales_manager'
  stages    Json
  createdAt DateTime @default(now()) @map("created_at")

  vacancy  Vacancy             @relation("SelectionTemplates", fields: [vacancyId], references: [id])
  sessions SelectionSession[]

  @@index([tenantId], map: "selection_templates_tenant_id_idx")
  @@index([vacancyId], map: "selection_templates_vacancy_id_idx")
  @@map("selection_templates")
}

model SelectionSession {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  applicationId String?   @db.Uuid @map("application_id")
  templateId    String    @db.Uuid @map("template_id")
  token         String    @unique @default(dbgenerated("uuidv7()"))
  status        String    @default("pending")
  // pending|stage_1|stage_2|stage_3|stage_4|completed|rejected|expired
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  template     SelectionTemplate      @relation(fields: [templateId], references: [id])
  stageResults SelectionStageResult[]
  verdict      SelectionVerdict?

  @@index([tenantId], map: "selection_sessions_tenant_id_idx")
  @@index([applicationId], map: "selection_sessions_application_id_idx")
  @@map("selection_sessions")
}

model SelectionStageResult {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  sessionId     String   @db.Uuid @map("session_id")
  stageNumber   Int      @map("stage_number")
  answers       Json
  scores        Json?
  flags         Json?
  aiEvaluation  Json?    @map("ai_evaluation")
  submittedAt   DateTime @default(now()) @map("submitted_at")

  session SelectionSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId], map: "selection_stage_results_session_id_idx")
  @@map("selection_stage_results")
}

model SelectionVerdict {
  id                 String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  sessionId          String   @unique @db.Uuid @map("session_id")
  verdict            String   // ДОПУСТИТЬ|ОТКЛОНИТЬ|НА РУЧНУЮ ПРОВЕРКУ HR
  totalWeightedScore Decimal? @map("total_weighted_score")
  stageScores        Json?    @map("stage_scores")
  crossCheckFlags    Json?    @map("cross_check_flags")
  lieScaleResult     Json?    @map("lie_scale_result")
  verdictReason      String?  @map("verdict_reason")
  hrNotes            String?  @map("hr_notes")
  createdAt          DateTime @default(now()) @map("created_at")

  session SelectionSession @relation(fields: [sessionId], references: [id])

  @@map("selection_verdicts")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 1F — Interview / Transcription / Protocol / Offer Draft
// ─────────────────────────────────────────────────────────────────────────────

enum InterviewStatus {
  created
  transcribing
  transcribed
  protocol_ready
  failed
}

model Interview {
  id                String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String          @db.Uuid @map("tenant_id")
  applicationId     String          @db.Uuid @map("application_id")
  scheduledAt       DateTime?       @map("scheduled_at")
  recordingUrl      String?         @map("recording_url")
  consentRecorded   Boolean         @default(false) @map("consent_recorded")
  status            InterviewStatus @default(created)
  transcript        Json?
  protocol          Json?
  offerDraft        Json?           @map("offer_draft")
  createdByUserId   String          @db.Uuid @map("created_by_user_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, map: "interviews_application_id_fkey")
  offers      Offer[]

  @@index([tenantId], map: "interviews_tenant_id_idx")
  @@index([applicationId], map: "interviews_application_id_idx")
  @@map("interviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 4.1 — Employee Lifecycle
// Spec: docs/employee-lifecycle-design.md §2 (+ §1.3 reuse).
// Tenant-scoped; uuidv7() PKs; snake_case via @map; invariants encoded as
// partial unique / CHECK constraints in the migration SQL.
// ─────────────────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  pre_onboarding
  onboarding
  probation
  active
  notice
  on_leave
  terminated
  alumni

  @@map("employee_status")
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship

  @@map("employment_type")
}

enum TerminationGround {
  voluntary_resignation
  involuntary
  end_of_contract
  probation_fail
  mutual_agreement
  retirement
  other

  @@map("termination_ground")
}

enum ProbationOutcome {
  passed
  failed
  extended

  @@map("probation_outcome")
}

enum OnboardingTaskStatus {
  pending
  in_progress
  completed
  skipped
  blocked

  @@map("onboarding_task_status")
}

enum LifecycleEventType {
  hired
  probation_started
  probation_passed
  probation_failed
  probation_extended
  role_change
  transfer
  leave_started
  leave_ended
  terminated
  rehired
  notice_started

  @@map("lifecycle_event_type")
}


enum AlumniStatus {
  active
  do_not_rehire
  archived

  @@map("alumni_status")
}

enum ExitReasonCategory {
  voluntary
  mutual
  probation_failed
  for_cause
  other

  @@map("exit_reason_category")
}

enum EmploymentDocumentType {
  offer_letter
  employment_contract
  nda
  addendum
  termination_letter
  certificate
  other

  @@map("employment_document_type")
}

enum EmploymentDocumentStatus {
  draft
  pending_signature
  signed
  declined
  expired
  archived

  @@map("employment_document_status")
}

enum PreStartPortalStatus {
  pending_link
  active
  closed

  @@map("pre_start_portal_status")
}

model Employee {
  id                String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String             @db.Uuid @map("tenant_id")
  userId            String?            @unique @db.Uuid @map("user_id")
  applicationId    String?            @unique @db.Uuid @map("application_id")
  candidateId       String?            @db.Uuid @map("candidate_id")
  requisitionId     String?            @db.Uuid @map("requisition_id")
  orgUnitId         String?            @db.Uuid @map("org_unit_id")
  fullName          String             @map("full_name")
  email             String?
  phone             String?
  jobTitle          String?            @map("job_title")
  grade             String?
  currency          String?
  agreedBaseSalary  Int?               @map("agreed_base_salary")
  agreedStartDate   DateTime?          @db.Date @map("agreed_start_date")
  employmentType    EmploymentType     @default(full_time) @map("employment_type")
  status            EmployeeStatus     @default(pre_onboarding)
  roleFamily        String?            @map("role_family")
  hireDate          DateTime?          @db.Date @map("hire_date")
  probationEndsAt   DateTime?          @map("probation_ends_at")
  probationOutcome  ProbationOutcome?  @map("probation_outcome")
  terminatedAt      DateTime?          @map("terminated_at")
  terminationGround TerminationGround? @map("termination_ground")
  terminationNote   String?            @map("termination_note")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")

  user            User?                    @relation(fields: [userId], references: [id], onDelete: SetNull, map: "employees_user_id_fkey")
  application     Application?             @relation(fields: [applicationId], references: [id], onDelete: SetNull, map: "employees_application_id_fkey")
  candidate       Candidate?               @relation(fields: [candidateId], references: [id], onDelete: SetNull, map: "employees_candidate_id_fkey")
  requisition     HiringRequisition?       @relation(fields: [requisitionId], references: [id], onDelete: SetNull, map: "employees_requisition_id_fkey")
  orgUnit         OrgUnit?                 @relation(fields: [orgUnitId], references: [id], onDelete: SetNull, map: "employees_org_unit_id_fkey")
  lifecycleEvents EmployeeLifecycleEvent[]
  checklists      OnboardingChecklist[]
  documents       EmploymentDocument[]
  preStartPortalEntry PreStartPortalEntry?
  offboardingChecklists OffboardingChecklist[]
  exitInterview         ExitInterview?
  alumniProfile         AlumniProfile?
  learningAssignments LearningAssignment[]
  oneOnOnes           OneOnOne[]
  reviewRequests      ReviewRequest[]
  okrs                Okr[]
  idps                Idp[]

  @@index([tenantId], map: "employees_tenant_id_idx")
  @@index([orgUnitId], map: "employees_org_unit_id_idx")
  @@index([candidateId], map: "employees_candidate_id_idx")
  @@index([requisitionId], map: "employees_requisition_id_idx")
  @@index([status], map: "employees_status_idx")
  @@index([userId], map: "employees_user_id_idx")
  @@index([roleFamily], map: "employees_role_family_idx")
  @@map("employees")
}

model EmployeeLifecycleEvent {
  id          String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String             @db.Uuid @map("tenant_id")
  employeeId  String             @db.Uuid @map("employee_id")
  type        LifecycleEventType
  fromStatus  EmployeeStatus?    @map("from_status")
  toStatus    EmployeeStatus?    @map("to_status")
  effectiveAt DateTime           @default(now()) @map("effective_at")
  actorUserId String?            @db.Uuid @map("actor_user_id")
  payload     Json?
  note        String?
  createdAt   DateTime           @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "employee_lifecycle_events_employee_id_fkey")

  @@index([tenantId], map: "employee_lifecycle_events_tenant_id_idx")
  @@index([employeeId, effectiveAt], map: "employee_lifecycle_events_employee_effective_idx")
  @@index([type], map: "employee_lifecycle_events_type_idx")
  @@map("employee_lifecycle_events")
}

model OnboardingChecklist {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  employeeId  String   @db.Uuid @map("employee_id")
  title       String
  description String?
  dueDate     DateTime? @db.Date @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  employee Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "onboarding_checklists_employee_id_fkey")
  tasks    OnboardingTask[]

  @@index([tenantId], map: "onboarding_checklists_tenant_id_idx")
  @@index([employeeId], map: "onboarding_checklists_employee_id_idx")
  @@map("onboarding_checklists")
}

model OnboardingTask {
  id              String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String               @db.Uuid @map("tenant_id")
  checklistId     String               @db.Uuid @map("checklist_id")
  order           Int                  @map("task_order")
  title           String
  description     String?
  status          OnboardingTaskStatus @default(pending)
  assigneeUserId  String?              @db.Uuid @map("assignee_user_id")
  dueDate         DateTime?            @db.Date @map("due_date")
  completedAt     DateTime?            @map("completed_at")
  completedByUserId String?            @db.Uuid @map("completed_by_user_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @default(now()) @updatedAt @map("updated_at")

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade, map: "onboarding_tasks_checklist_id_fkey")

  @@index([tenantId], map: "onboarding_tasks_tenant_id_idx")
  @@index([checklistId], map: "onboarding_tasks_checklist_id_idx")
  @@index([status], map: "onboarding_tasks_status_idx")
  @@unique([checklistId, order], map: "onboarding_tasks_checklist_order_key")
  @@map("onboarding_tasks")
}

model EmploymentDocument {
  id           String                   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId     String                   @db.Uuid @map("tenant_id")
  employeeId   String                   @db.Uuid @map("employee_id")
  type         EmploymentDocumentType
  status       EmploymentDocumentStatus @default(draft)
  title        String
  fileUrl      String?                  @map("file_url")
  metadata     Json?
  issuedAt     DateTime?                @map("issued_at")
  signedAt     DateTime?                @map("signed_at")
  expiresAt    DateTime?                @map("expires_at")
  createdByUserId String                @db.Uuid @map("created_by_user_id")
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @default(now()) @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "employment_documents_employee_id_fkey")

  @@index([tenantId], map: "employment_documents_tenant_id_idx")
  @@index([employeeId], map: "employment_documents_employee_id_idx")
  @@index([type], map: "employment_documents_type_idx")
  @@index([status], map: "employment_documents_status_idx")
  @@map("employment_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 4.7 — Pre-start inbox / first-day plan
// Spec: docs/employee-lifecycle-design.md §5.3 (roadmap §7.4).
// Opened on `Application.offer → hired` alongside the Employee row. Gated by
// `Employee.user_id IS NOT NULL`: while no portal user is linked the entry
// sits in `pending_link` and surfaces nothing to the candidate.
// ─────────────────────────────────────────────────────────────────────────────

model PreStartPortalEntry {
  id         String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId   String               @db.Uuid @map("tenant_id")
  employeeId String               @unique @db.Uuid @map("employee_id")
  status     PreStartPortalStatus @default(pending_link)
  openedAt   DateTime             @default(now()) @map("opened_at")
  linkedAt   DateTime?            @map("linked_at")
  closedAt   DateTime?            @map("closed_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @default(now()) @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "pre_start_portal_entries_employee_id_fkey")

  @@index([tenantId], map: "pre_start_portal_entries_tenant_id_idx")
  @@index([status], map: "pre_start_portal_entries_status_idx")
  @@map("pre_start_portal_entries")
}


model OffboardingChecklist {
  id          String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String    @db.Uuid @map("tenant_id")
  employeeId  String    @db.Uuid @map("employee_id")
  title       String
  description String?
  dueDate     DateTime? @db.Date @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "offboarding_checklists_employee_id_fkey")
  tasks    OffboardingTask[]

  @@index([tenantId], map: "offboarding_checklists_tenant_id_idx")
  @@index([employeeId], map: "offboarding_checklists_employee_id_idx")
  @@map("offboarding_checklists")
}

model OffboardingTask {
  id                String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String               @db.Uuid @map("tenant_id")
  checklistId       String               @db.Uuid @map("checklist_id")
  order             Int                  @map("task_order")
  title             String
  description       String?
  assigneeRole      String               @map("assignee_role")
  status            OnboardingTaskStatus @default(pending)
  assigneeUserId    String?              @db.Uuid @map("assignee_user_id")
  dueDate           DateTime?            @db.Date @map("due_date")
  completedAt       DateTime?            @map("completed_at")
  completedByUserId String?              @db.Uuid @map("completed_by_user_id")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @default(now()) @updatedAt @map("updated_at")

  checklist OffboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade, map: "offboarding_tasks_checklist_id_fkey")

  @@index([tenantId], map: "offboarding_tasks_tenant_id_idx")
  @@index([checklistId], map: "offboarding_tasks_checklist_id_idx")
  @@index([status], map: "offboarding_tasks_status_idx")
  @@unique([checklistId, order], map: "offboarding_tasks_checklist_order_key")
  @@map("offboarding_tasks")
}

model ExitInterview {
  id                 String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId           String             @db.Uuid @map("tenant_id")
  employeeId         String             @unique @db.Uuid @map("employee_id")
  conductedByUserId  String?            @db.Uuid @map("conducted_by_user_id")
  conductedAt        DateTime?          @map("conducted_at")
  reasonCategory     ExitReasonCategory @map("reason_category")
  notes              String?
  wouldRehire        Boolean?           @map("would_rehire")
  metadata           Json?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "exit_interviews_employee_id_fkey")

  @@index([tenantId], map: "exit_interviews_tenant_id_idx")
  @@map("exit_interviews")
}

model AlumniProfile {
  id                  String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId            String       @db.Uuid @map("tenant_id")
  employeeId          String       @unique @db.Uuid @map("employee_id")
  candidateId         String?      @db.Uuid @map("candidate_id")
  status              AlumniStatus @default(active)
  wouldRehire         Boolean?     @map("would_rehire")
  departureReason     String?      @map("departure_reason")
  rehireEligibleFrom  DateTime?    @db.Date @map("rehire_eligible_from")
  tags                String[]     @default([])
  notes               String?
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at")

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "alumni_profiles_employee_id_fkey")
  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull, map: "alumni_profiles_candidate_id_fkey")

  @@index([tenantId], map: "alumni_profiles_tenant_id_idx")
  @@index([status], map: "alumni_profiles_status_idx")
  @@map("alumni_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Offer lifecycle + Compensation calculator
// Spec: docs/contracts/20-fsm.md (Offer), docs/contracts/10-data-model.md.
// ─────────────────────────────────────────────────────────────────────────────

model Offer {
  id                    String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId              String       @db.Uuid @map("tenant_id")
  applicationId         String       @db.Uuid @map("application_id")
  interviewId           String?      @db.Uuid @map("interview_id")
  salary                Int
  currency              Currency
  startDate             DateTime     @map("start_date") @db.Date
  grade                 String?
  conditions            String[]     @default([])
  status                OfferStatus  @default(draft)
  docusealSubmissionId  String?      @map("docuseal_submission_id")
  docusealDocumentUrl   String?      @map("docuseal_document_url")
  docusealSigningUrl    String?      @map("docuseal_signing_url")
  sentAt                DateTime?    @map("sent_at")
  expiresAt             DateTime?    @map("expires_at")
  acceptedAt            DateTime?    @map("accepted_at")
  declinedAt            DateTime?    @map("declined_at")
  declinedReason        String?      @map("declined_reason")
  createdByUserId       String       @db.Uuid @map("created_by_user_id")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, map: "offers_application_id_fkey")
  interview   Interview?  @relation(fields: [interviewId], references: [id], onDelete: SetNull, map: "offers_interview_id_fkey")

  @@index([tenantId], map: "offers_tenant_id_idx")
  @@index([applicationId], map: "offers_application_id_idx")
  @@index([status, expiresAt], map: "offers_status_expires_at_idx")
  @@map("offers")
}

model CompBand {
  id          String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String    @db.Uuid @map("tenant_id")
  grade       String
  currency    Currency
  minSalary   Int       @map("min_salary")
  midSalary   Int       @map("mid_salary")
  maxSalary   Int       @map("max_salary")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, grade, currency], map: "comp_bands_tenant_grade_currency_unique")
  @@index([tenantId], map: "comp_bands_tenant_id_idx")
  @@map("comp_bands")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 6 — Learning & Performance (LMS, 1:1s, 360° Reviews, OKRs, IDPs)
