  tasks    OffboardingTask[]

  @@index([tenantId], map: "offboarding_checklists_tenant_id_idx")
  @@index([employeeId], map: "offboarding_checklists_employee_id_idx")
  @@map("offboarding_checklists")
}

model OffboardingTask {
  id                String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId          String               @map("tenant_id") @db.Uuid
  checklistId       String               @map("checklist_id") @db.Uuid
  order             Int                  @map("task_order")
