  plan CompPlan @relation(fields: [planId], references: [id], onDelete: Cascade, map: "comp_plan_items_plan_id_fkey")

  @@unique([planId, employeeId], map: "comp_plan_items_plan_employee_unique")
  @@index([tenantId], map: "comp_plan_items_tenant_id_idx")
  @@index([planId], map: "comp_plan_items_plan_id_idx")
  @@index([employeeId], map: "comp_plan_items_employee_id_idx")
  @@map("comp_plan_items")
}

