---
// Site-wide layout used by every careers page.
// Inline CSS keeps the static bundle tiny — no client framework, no JS by default.
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = `${title} — Careers`;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>
    <style>
      :root {
        color-scheme: light;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        --fg: #14221f;
        --muted: #4c6f5b;
        --bg: #f6f8fb;
        --card: #ffffff;
        --accent: #1a6f45;
        --accent-fg: #ffffff;
        --border: #d6dfd8;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--fg);
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      main { max-width: 880px; margin: 0 auto; padding: 3rem 1.5rem; }
      h1 { margin: 0 0 .5rem; font-size: 2.5rem; line-height: 1.1; }
      h2 { margin: 0 0 .5rem; font-size: 1.5rem; }
      .eyebrow {
        margin: 0 0 1rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
      }
      .card h2 { margin-bottom: .25rem; font-size: 1.25rem; }
      .card p { margin: .25rem 0 0; color: var(--muted); }
      .breadcrumb {
        margin-bottom: 1.5rem;
        font-size: .9rem;
        color: var(--muted);
      }
      .button {
        display: inline-block;
        background: var(--accent);
        color: var(--accent-fg);
        padding: .75rem 1.25rem;
        border-radius: 6px;
        border: 0;
        font-weight: 600;
        cursor: pointer;
        font-size: 1rem;
      }
      .button:hover { text-decoration: none; opacity: .92; }
      .field { display: block; margin-bottom: 1rem; }
      .field label { display: block; font-weight: 600; margin-bottom: .25rem; }
      .field input,
      .field textarea {
        width: 100%;
        box-sizing: border-box;
        padding: .6rem .75rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        font: inherit;
      }
      .field textarea { min-height: 7rem; resize: vertical; }
      .field .hint { font-size: .85rem; color: var(--muted); margin-top: .25rem; }
      .honeypot {
        position: absolute;
        left: -10000px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }
      .alert {
        padding: .75rem 1rem;
        border-radius: 6px;
        margin-bottom: 1rem;
        background: #fff3cd;
        border: 1px solid #f5c97c;
      }
      .alert.success { background: #def7e2; border-color: #97d6a4; }
      .alert.error { background: #fde2e2; border-color: #f5a3a3; }
      .empty {
        padding: 2rem;
        text-align: center;
        color: var(--muted);
        background: var(--card);
        border-radius: 8px;
        border: 1px dashed var(--border);
      }
      .prose { white-space: pre-wrap; line-height: 1.55; }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
